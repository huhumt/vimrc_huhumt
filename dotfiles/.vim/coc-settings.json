{
    "suggest.noselect": true,
    "inlayHint.display": false,
    "clangd.path": "/usr/bin/clangd-19",
    "clangd.disableDiagnostics": false,
    "python.pythonPath": "/usr/bin/python3",
    "python.linting.pylamaEnabled": true,
    "pyright.organizeimports.provider": "isort",
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.updates.prompt": false,
    "cSpell.language": "en-GB",
    "cSpell.numSuggestions": 4,
    "cSpell.allowCompoundWords": true,
    "biome.bin": "/usr/local/bin/biome",
    "biome.requireConfiguration": false,
    "[java]": {
        "semanticTokens.enable": true
    }
}
